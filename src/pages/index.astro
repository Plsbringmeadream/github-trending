---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import FilterBar from '../components/FilterBar.astro';
import StatsBar from '../components/StatsBar.astro';
import ProjectCard from '../components/ProjectCard.astro';
import Pagination from '../components/Pagination.astro';
import AiChat from '../components/AiChat.astro';
import LanguageChart from '../components/LanguageChart.astro';
import { fetchTrendingRepos } from '../lib/github';

const lang = Astro.url.searchParams.get('lang') || 'All';
const sort = Astro.url.searchParams.get('sort') || 'stars';
const page = Math.max(1, parseInt(Astro.url.searchParams.get('page') || '1', 10) || 1);
const days = Math.min(30, Math.max(1, parseInt(Astro.url.searchParams.get('days') || '30', 10) || 30));
const perPage = 30;

let repos: any[] = [];
let totalCount = 0;
let totalStars = 0;
let errorMsg = '';

try {
  const token = import.meta.env.GITHUB_TOKEN || process.env.GITHUB_TOKEN;
  const data = await fetchTrendingRepos(lang === 'All' ? undefined : lang, days, page, perPage, sort, token);
  repos = data.repos;
  totalCount = data.totalCount;
  totalStars = repos.reduce((sum: number, r: any) => sum + r.stargazers_count, 0);
} catch (err: any) {
  errorMsg = err.message || 'Failed to fetch trending repositories';
}

const totalPages = Math.ceil(totalCount / perPage);

const langCounts: Record<string, number> = {};
repos.forEach((r: any) => {
  const l = r.language || 'Other';
  langCounts[l] = (langCounts[l] || 0) + 1;
});
const topLang = Object.entries(langCounts).sort((a, b) => b[1] - a[1])[0]?.[0] || 'N/A';
---

<Layout title="GitHub Trending - AI-Powered Repository Discovery">
  <!-- Hero Section -->
  <header class="relative overflow-hidden" style="border-bottom: 1px solid var(--border);">
    <!-- Animated glow background -->
    <div class="absolute inset-0 opacity-30">
      <div class="absolute inset-0" style="background: radial-gradient(ellipse at 30% 20%, var(--hero-glow-1) 0%, transparent 50%);"></div>
      <div class="absolute inset-0" style="background: radial-gradient(ellipse at 70% 80%, var(--hero-glow-2) 0%, transparent 50%);"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 py-8 sm:py-12">
      <!-- Top bar -->
      <div class="flex items-center justify-between mb-8">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background: linear-gradient(135deg, var(--gradient-start), var(--gradient-end));">
            <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 16 16">
              <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"></path>
            </svg>
          </div>
          <div>
            <h1 class="text-lg font-bold" style="color: var(--text);">GitHub Trending</h1>
          </div>
        </div>
        <div class="flex items-center gap-2">
          <!-- Theme toggle -->
          <button id="theme-toggle" class="theme-toggle" aria-label="Toggle theme">
            <span class="sun">☀️</span>
            <span class="moon">🌙</span>
          </button>
          <span class="inline-flex items-center gap-1.5 px-3 py-1 text-xs font-medium rounded-full" style="background: rgba(22,163,74,0.1); color: var(--green); border: 1px solid rgba(22,163,74,0.2);">
            <span class="w-1.5 h-1.5 rounded-full animate-pulse" style="background: var(--green);"></span>
            Live Data
          </span>
          <span class="hidden sm:inline-flex items-center gap-1.5 px-3 py-1 text-xs font-medium rounded-full" style="background: rgba(99,102,241,0.1); color: var(--accent); border: 1px solid rgba(99,102,241,0.2);">
            🧠 AI-Powered
          </span>
        </div>
      </div>

      <!-- Hero text -->
      <div class="text-center max-w-3xl mx-auto mb-6">
        <div class="inline-flex items-center gap-2 px-3 py-1 mb-4 text-xs font-medium rounded-full" style="background: rgba(99,102,241,0.1); color: var(--accent); border: 1px solid rgba(99,102,241,0.2);">
          <span class="w-2 h-2 rounded-full animate-pulse" style="background: var(--accent);"></span>
          Live GitHub Intelligence
        </div>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold mb-4 leading-tight">
          <span class="gradient-text">Discover the Next Breakout</span>
          <br />
          <span style="color: var(--text);">GitHub Repositories</span>
        </h2>
        <p class="text-base sm:text-lg max-w-2xl mx-auto" style="color: var(--text-secondary);">
          AI-powered analysis of trending open source projects. Track stars, languages, and repo growth in real time.
        </p>
      </div>

      <!-- Action buttons -->
      <div class="flex items-center justify-center gap-3 flex-wrap">
        <button id="batch-summary-btn" class="btn-glow flex items-center gap-2 px-4 py-2 text-sm rounded-xl glass glass-hover transition-all duration-300 cursor-pointer" style="color: var(--text-secondary);">
          <span class="text-base">🧠</span> AI Insight
        </button>
        <button id="ai-recommend-btn" class="btn-glow flex items-center gap-2 px-4 py-2 text-sm rounded-xl glass glass-hover transition-all duration-300 cursor-pointer" style="color: var(--text-secondary);">
          <span class="text-base">🎯</span> AI Picks
        </button>
        <button id="favorites-toggle" class="btn-glow flex items-center gap-2 px-4 py-2 text-sm rounded-xl glass glass-hover transition-all duration-300 cursor-pointer" style="color: var(--text-secondary);">
          <span class="text-base">⭐</span>
          <span id="favorites-count">0</span>
        </button>
      </div>
    </div>
  </header>

  <FilterBar currentLanguage={lang} currentSort={sort} currentDays={days} />

  {errorMsg ? (
    <div class="max-w-7xl mx-auto px-4 py-20 text-center page-animate">
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl mb-6" style="background: rgba(220,38,38,0.1); border: 1px solid rgba(220,38,38,0.2);">
        <svg class="w-8 h-8" style="color: var(--fire);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.072 16.5c-.77.833.192 2.5 1.732 2.5z"></path>
        </svg>
      </div>
      <h2 class="text-xl font-semibold mb-2" style="color: var(--text);">Oops! Something went wrong</h2>
      <p class="max-w-md mx-auto mb-6" style="color: var(--text-secondary);">{errorMsg}</p>
      <a href="/" class="inline-flex items-center gap-2 px-5 py-2.5 text-white rounded-xl font-medium hover:opacity-90 transition-opacity" style="background: linear-gradient(135deg, var(--gradient-start), var(--gradient-end));">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
        </svg>
        Try Again
      </a>
      <p class="text-xs mt-4" style="color: var(--text-secondary);">
        Tip: Set a GITHUB_TOKEN environment variable to increase API rate limits.
      </p>
    </div>
  ) : (
    <>
      <StatsBar totalCount={totalCount} totalStars={totalStars} currentLanguage={lang} currentDays={days} topLang={topLang} />

      <LanguageChart repos={repos} currentLanguage={lang} currentSort={sort} currentDays={days} />

      <main class="max-w-7xl mx-auto px-4 pb-12">
        <!-- Search box + compare hint -->
        <div class="mb-6 flex flex-col sm:flex-row sm:items-start gap-3 page-animate" style="animation-delay: 0.2s;">
          <div class="flex-1">
            <div class="relative max-w-md">
              <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4" style="color: var(--text-secondary);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
              </svg>
              <input
                id="search-input"
                type="text"
                placeholder="Search repositories..."
                class="w-full pl-10 pr-10 py-2.5 glass rounded-xl text-sm focus:outline-none transition-colors"
                style="color: var(--text);"
              />
              <button id="search-clear" class="absolute right-3 top-1/2 -translate-y-1/2 hidden cursor-pointer" style="color: var(--text-secondary);" title="Clear search">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
              </button>
            </div>
            <p id="search-count" class="text-xs mt-2 hidden" style="color: var(--text-secondary);"></p>
          </div>
          <div id="compare-hint" class="hidden sm:flex items-center gap-2 px-3 py-2 glass rounded-xl text-xs" style="color: var(--orange);">
            <span>⚖️</span>
            <span>Click two repos' <strong>Compare</strong> to analyze</span>
            <button id="compare-clear-btn" class="ml-1 cursor-pointer" style="color: var(--text-secondary);" title="Clear selection">&times;</button>
          </div>
        </div>

        <div id="repo-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
          {repos.map((repo: any, i: number) => (
            <ProjectCard repo={repo} rank={(page - 1) * perPage + i + 1} />
          ))}
        </div>

        {repos.length === 0 && (
          <div class="text-center py-20">
            <p class="text-lg" style="color: var(--text-secondary);">No repositories found for this filter.</p>
            <a href="/" class="inline-block mt-4 hover:underline" style="color: var(--accent);">View all trending repos</a>
          </div>
        )}

        <Pagination currentPage={page} totalPages={totalPages} language={lang} sort={sort} days={days} />
      </main>
    </>
  )}

  <footer class="py-6 text-center text-sm" style="border-top: 1px solid var(--border); color: var(--text-secondary);">
    <p>
      Data from <a href="https://github.com" class="hover:underline" style="color: var(--accent);" target="_blank" rel="noopener noreferrer">GitHub</a>
      &middot; Built with <a href="https://astro.build" class="hover:underline" style="color: var(--accent);" target="_blank" rel="noopener noreferrer">Astro</a>
    </p>
  </footer>

  <AiChat />

  <!-- Theme toggle script -->
  <script>
    const themeToggle = document.getElementById('theme-toggle');
    if (themeToggle) {
      themeToggle.addEventListener('click', () => {
        const isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      });
    }
  </script>

  <!-- Client-side logic -->
  <script define:vars={{ reposData: repos }}>
    (() => {
      const searchInput = document.getElementById('search-input');
      const searchClear = document.getElementById('search-clear');
      const searchCount = document.getElementById('search-count');
      const repoGrid = document.getElementById('repo-grid');
      const favoritesToggle = document.getElementById('favorites-toggle');
      const favoritesCountEl = document.getElementById('favorites-count');
      const batchSummaryBtn = document.getElementById('batch-summary-btn');
      const aiRecommendBtn = document.getElementById('ai-recommend-btn');
      const compareHint = document.getElementById('compare-hint');
      const compareClearBtn = document.getElementById('compare-clear-btn');

      if (!searchInput || !repoGrid) return;

      // --- Compare state ---
      const compareState = { selected: [] };

      function updateCompareHint() {
        if (compareHint) {
          if (compareState.selected.length > 0) {
            compareHint.classList.remove('hidden');
            compareHint.classList.add('sm:flex');
          } else {
            compareHint.classList.add('hidden');
            compareHint.classList.remove('sm:flex');
          }
        }
      }

      function clearCompareState() {
        compareState.selected = [];
        document.querySelectorAll('.compare-btn').forEach(btn => {
          btn.classList.remove('active');
        });
        updateCompareHint();
      }

      if (compareClearBtn) {
        compareClearBtn.addEventListener('click', clearCompareState);
      }

      window.__getCompareState = () => ({
        selected: compareState.selected,
        clear: clearCompareState,
      });

      // --- AI buttons ---
      function collectVisibleRepos() {
        const cards = repoGrid.querySelectorAll('article');
        const visible = [];
        cards.forEach(card => {
          if (card.style.display === 'none') return;
          const aiBtn = card.querySelector('.ai-summary-btn');
          if (aiBtn) {
            try {
              visible.push(JSON.parse(aiBtn.getAttribute('data-repo') || '{}'));
            } catch {}
          }
        });
        return visible;
      }

      if (batchSummaryBtn) {
        batchSummaryBtn.addEventListener('click', () => {
          const repos = collectVisibleRepos();
          if (repos.length && window.openAiBatchSummary) {
            window.openAiBatchSummary(repos);
          }
        });
      }

      if (aiRecommendBtn) {
        aiRecommendBtn.addEventListener('click', () => {
          const repos = collectVisibleRepos();
          if (repos.length && window.openAiRecommend) {
            window.openAiRecommend(repos);
          }
        });
      }

      // --- Favorites ---
      const FAV_KEY = 'github…ites';

      function getFavorites() {
        try { return JSON.parse(localStorage.getItem(FAV_KEY) || '[]'); } catch { return []; }
      }

      function saveFavorites(favs) {
        localStorage.setItem(FAV_KEY, JSON.stringify(favs));
      }

      function updateFavoritesCount() {
        const favs = getFavorites();
        favoritesCountEl.textContent = String(favs.length);
      }

      updateFavoritesCount();

      window.__toggleFavorite = function(fullName) {
        const favs = getFavorites();
        const idx = favs.indexOf(fullName);
        if (idx >= 0) favs.splice(idx, 1);
        else favs.push(fullName);
        saveFavorites(favs);
        updateFavoritesCount();
        document.querySelectorAll(`[data-fav-btn="${fullName}"]`).forEach(btn => {
          const icon = btn.querySelector('.fav-icon');
          if (icon) icon.textContent = favs.includes(fullName) ? '★' : '☆';
          if (favs.includes(fullName)) {
            btn.style.color = 'var(--orange)';
          } else {
            btn.style.color = 'var(--text-secondary)';
          }
        });
      };

      // --- Search ---
      function doSearch() {
        const q = searchInput.value.trim().toLowerCase();
        const cards = repoGrid.querySelectorAll('article');
        let visible = 0;
        cards.forEach(card => {
          const name = (card.querySelector('a')?.textContent || '').toLowerCase();
          const desc = (card.querySelector('p')?.textContent || '').toLowerCase();
          const match = !q || name.includes(q) || desc.includes(q);
          card.style.display = match ? '' : 'none';
          if (match) visible++;
        });
        if (q) {
          searchCount.textContent = `${visible} of ${cards.length} repositories match "${searchInput.value.trim()}"`;
          searchCount.classList.remove('hidden');
        } else {
          searchCount.classList.add('hidden');
        }
        searchClear.classList.toggle('hidden', !q);
      }

      searchInput.addEventListener('input', doSearch);
      searchClear.addEventListener('click', () => {
        searchInput.value = '';
        doSearch();
        searchInput.focus();
      });

      // --- Favorites filter ---
      let showingFavoritesOnly = false;
      favoritesToggle.addEventListener('click', () => {
        showingFavoritesOnly = !showingFavoritesOnly;
        const favs = getFavorites();
        const cards = repoGrid.querySelectorAll('article');
        cards.forEach(card => {
          const fullName = card.getAttribute('data-repo-name') || '';
          if (showingFavoritesOnly) {
            card.style.display = favs.includes(fullName) ? '' : 'none';
          } else {
            card.style.display = '';
          }
        });
        if (showingFavoritesOnly) {
          favoritesToggle.style.borderColor = 'var(--orange)';
          favoritesToggle.style.color = 'var(--orange)';
        } else {
          favoritesToggle.style.borderColor = '';
          favoritesToggle.style.color = '';
        }
      });
    })();
  </script>
</Layout>
