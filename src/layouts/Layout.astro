---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Discover the hottest GitHub repositories from the last 30 days. AI-powered analysis, trending data, and open source discovery." } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
  </head>
  <body class="min-h-screen bg-neon-bg text-neon-text font-sans grid-bg relative">
    <div id="mouse-glow"></div>
    <div class="relative z-10">
      <slot />
    </div>
  </body>
</html>

<script>
  // Mouse-following glow effect
  const glow = document.getElementById('mouse-glow');
  if (glow) {
    let rafId: number;
    document.addEventListener('mousemove', (e) => {
      cancelAnimationFrame(rafId);
      rafId = requestAnimationFrame(() => {
        glow.style.transform = `translate(${e.clientX - 200}px, ${e.clientY - 200}px)`;
      });
    });
  }
</script>

<style is:global>
  @import '../styles/global.css';
</style>
