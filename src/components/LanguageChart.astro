---
import { getLanguageColor } from '../lib/github';

interface Props {
  repos: Array<{ language: string | null; stargazers_count: number }>;
  currentLanguage: string;
  currentSort: string;
  currentDays: number;
}

const { repos, currentLanguage, currentSort, currentDays } = Astro.props;

const langCounts: Record<string, number> = {};
repos.forEach(r => {
  const lang = r.language || 'Other';
  langCounts[lang] = (langCounts[lang] || 0) + 1;
});

const sorted = Object.entries(langCounts)
  .filter(([_, count]) => count >= 1)
  .sort((a, b) => b[1] - a[1]);

const total = sorted.reduce((sum, [_, c]) => sum + c, 0);
const maxCount = sorted.length > 0 ? sorted[0][1] : 1;

const barHeight = 22;
const gap = 6;
const chartHeight = sorted.length * (barHeight + gap);
const labelWidth = 90;
const countWidth = 36;
const barAreaWidth = 200;
const svgWidth = labelWidth + barAreaWidth + countWidth + 16;
---

{sorted.length > 0 && (
  <div class="max-w-7xl mx-auto px-4 pb-4 page-animate" style="animation-delay: 0.15s;">
    <div class="glass rounded-xl p-5">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-sm font-semibold flex items-center gap-2" style="color: var(--text);">
          <svg class="w-4 h-4" style="color: var(--accent);" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z"></path>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z"></path>
          </svg>
          Language Distribution
        </h3>
        <span class="text-xs" style="color: var(--text-secondary);">{total} repos</span>
      </div>

      <svg width={svgWidth} height={chartHeight} class="w-full" viewBox={`0 0 ${svgWidth} ${chartHeight}`} preserveAspectRatio="xMinYMin meet">
        {sorted.map(([lang, count], i) => {
          const y = i * (barHeight + gap);
          const barWidth = (count / maxCount) * barAreaWidth;
          const color = lang === 'Other' ? '#64748b' : getLanguageColor(lang);
          const isFiltered = currentLanguage === lang;
          const href = isFiltered
            ? `/?sort=${currentSort}&days=${currentDays}`
            : `/?lang=${encodeURIComponent(lang)}&sort=${currentSort}&days=${currentDays}`;
          return (
            <g>
              <a href={href}>
                <text
                  x={labelWidth - 8}
                  y={y + barHeight / 2 + 1}
                  text-anchor="end"
                  dominant-baseline="central"
                  style={`font-size: 12px; fill: ${isFiltered ? 'var(--accent)' : 'var(--text-secondary)'}; font-weight: ${isFiltered ? '600' : '400'};`}
                >
                  {lang}
                </text>
                <rect
                  x={labelWidth}
                  y={y + 2}
                  width={barAreaWidth}
                  height={barHeight - 4}
                  rx={3}
                  style="fill: var(--code-bg);"
                />
                <rect
                  x={labelWidth}
                  y={y + 2}
                  width={barWidth}
                  height={barHeight - 4}
                  rx={3}
                  fill={color}
                  opacity={isFiltered ? 1 : 0.7}
                  class="cursor-pointer hover:opacity-100 transition-opacity"
                />
                <text
                  x={labelWidth + barAreaWidth + 8}
                  y={y + barHeight / 2 + 1}
                  dominant-baseline="central"
                  style="font-size: 12px; fill: var(--text-secondary);"
                >
                  {count}
                </text>
              </a>
            </g>
          );
        })}
      </svg>
    </div>
  </div>
)}
