---
interface Props {
  currentPage: number;
  totalPages: number;
  language: string;
  sort: string;
  days: number;
}

const { currentPage, totalPages, language, sort, days = 30 } = Astro.props;

function getPageUrl(page: number): string {
  return `/?lang=${encodeURIComponent(language)}&sort=${sort}&days=${days}&page=${page}`;
}

const maxVisible = 5;
let startPage = Math.max(1, currentPage - Math.floor(maxVisible / 2));
let endPage = Math.min(totalPages, startPage + maxVisible - 1);
if (endPage - startPage + 1 < maxVisible) {
  startPage = Math.max(1, endPage - maxVisible + 1);
}

const pages: (number | string)[] = [];
if (startPage > 1) {
  pages.push(1);
  if (startPage > 2) pages.push('...');
}
for (let i = startPage; i <= endPage; i++) {
  pages.push(i);
}
if (endPage < totalPages) {
  if (endPage < totalPages - 1) pages.push('...');
  pages.push(totalPages);
}
---

{totalPages > 1 && (
  <nav class="flex items-center justify-center gap-2 mt-8" aria-label="Pagination">
    {currentPage > 1 && (
      <a
        href={getPageUrl(currentPage - 1)}
        class="px-3 py-2 glass rounded-lg text-sm hover:opacity-80 transition-colors"
        style="color: var(--text-secondary);"
        aria-label="Previous page"
      >
        ← Prev
      </a>
    )}

    {pages.map((page) => (
      typeof page === 'number' ? (
        <a
          href={getPageUrl(page)}
          class:list={[
            'px-3 py-2 rounded-lg text-sm transition-all duration-200 min-w-[36px] text-center',
            page === currentPage ? 'text-white font-semibold shadow-lg' : 'glass hover:opacity-80',
          ]}
          style={page === currentPage
            ? 'background: linear-gradient(135deg, var(--gradient-start), var(--purple)); box-shadow: 0 4px 12px rgba(99,102,241,0.3);'
            : 'color: var(--text-secondary);'}
          aria-current={page === currentPage ? 'page' : undefined}
        >
          {page}
        </a>
      ) : (
        <span class="px-2" style="color: var(--text-secondary);">…</span>
      )
    ))}

    {currentPage < totalPages && (
      <a
        href={getPageUrl(currentPage + 1)}
        class="px-3 py-2 glass rounded-lg text-sm hover:opacity-80 transition-colors"
        style="color: var(--text-secondary);"
        aria-label="Next page"
      >
        Next →
      </a>
    )}
  </nav>
)}
