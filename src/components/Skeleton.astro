---
// Skeleton.astro - Loading skeleton placeholder
---

<div class="skeleton-container max-w-7xl mx-auto px-4 py-6">
  <!-- Stats skeleton -->
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
    {[1,2,3,4].map(() => (
      <div class="glass rounded-xl p-4">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-lg skeleton-shimmer"></div>
          <div class="flex-1">
            <div class="h-6 w-16 rounded skeleton-shimmer mb-1"></div>
            <div class="h-3 w-24 rounded skeleton-shimmer"></div>
          </div>
        </div>
      </div>
    ))}
  </div>

  <!-- Chart skeleton -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-6">
    <div class="glass rounded-xl p-5">
      <div class="h-4 w-32 rounded skeleton-shimmer mb-4"></div>
      {[1,2,3,4,5].map(() => (
        <div class="flex items-center gap-3 mb-3">
          <div class="h-4 w-16 rounded skeleton-shimmer"></div>
          <div class="flex-1 h-5 rounded-full skeleton-shimmer"></div>
          <div class="h-4 w-8 rounded skeleton-shimmer"></div>
        </div>
      ))}
    </div>
    <div class="glass rounded-xl p-5">
      <div class="h-4 w-24 rounded skeleton-shimmer mb-4"></div>
      <div class="flex flex-wrap gap-2">
        {[1,2,3,4,5,6,7,8].map(() => (
          <div class="h-7 rounded-full skeleton-shimmer" style={`width: ${40 + Math.random() * 60}px;`}></div>
        ))}
      </div>
    </div>
  </div>

  <!-- Card skeletons -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
    {[1,2,3,4,5,6].map(() => (
      <div class="glass rounded-xl p-5">
        <div class="flex items-start gap-3 mb-3">
          <div class="w-10 h-10 rounded-full skeleton-shimmer"></div>
          <div class="flex-1">
            <div class="h-5 w-40 rounded skeleton-shimmer mb-2"></div>
            <div class="h-3 w-full rounded skeleton-shimmer mb-1"></div>
            <div class="h-3 w-3/4 rounded skeleton-shimmer"></div>
          </div>
        </div>
        <div class="flex items-center gap-4 mt-4">
          <div class="h-4 w-16 rounded skeleton-shimmer"></div>
          <div class="h-4 w-12 rounded skeleton-shimmer"></div>
          <div class="h-4 w-20 rounded skeleton-shimmer ml-auto"></div>
        </div>
        <div class="flex gap-2 mt-4 pt-3" style="border-top: 1px solid var(--border);">
          <div class="flex-1 h-9 rounded-lg skeleton-shimmer"></div>
          <div class="w-9 h-9 rounded-lg skeleton-shimmer"></div>
          <div class="flex-1 h-9 rounded-lg skeleton-shimmer"></div>
        </div>
      </div>
    ))}
  </div>
</div>

<style>
  .skeleton-shimmer {
    background: linear-gradient(
      90deg,
      var(--glass-border) 25%,
      rgba(129,140,248,0.12) 50%,
      var(--glass-border) 75%
    );
    background-size: 200% 100%;
    animation: shimmer 1.8s ease-in-out infinite;
    border-radius: 6px;
  }

  @keyframes shimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }
</style>
