---
import { LANGUAGES, SORT_OPTIONS } from '../lib/github';

interface Props {
  currentLanguage: string;
  currentSort: string;
  currentDays: number;
}

const { currentLanguage, currentSort, currentDays } = Astro.props;

const DAYS_OPTIONS = [
  { value: 7, label: '7d' },
  { value: 14, label: '14d' },
  { value: 30, label: '30d' },
];
---

<div class="sticky top-0 z-50 glass border-b border-neon-border">
  <div class="max-w-7xl mx-auto px-4 py-3">
    <div class="flex flex-col sm:flex-row items-start sm:items-center gap-3">
      <!-- Language filters -->
      <div class="flex gap-1.5 flex-1 overflow-x-auto pb-1 scrollbar-hide">
        {LANGUAGES.map((lang) => (
          <a
            href={`/?lang=${encodeURIComponent(lang)}&sort=${currentSort}&days=${currentDays}`}
            class:list={[
              'pill-tab px-3 py-1.5 text-sm rounded-full whitespace-nowrap transition-all duration-250',
              currentLanguage === lang
                ? 'bg-gradient-to-r from-neon-accent to-neon-purple text-white font-semibold shadow-lg shadow-neon-accent/20'
                : 'glass text-neon-text-secondary hover:text-neon-text hover:border-neon-accent/30',
            ]}
          >
            {lang}
          </a>
        ))}
      </div>

      <!-- Controls group -->
      <div class="flex items-center gap-2">
        <!-- Time range selector -->
        <div class="flex items-center glass rounded-xl overflow-hidden">
          {DAYS_OPTIONS.map((opt) => (
            <a
              href={`/?lang=${encodeURIComponent(currentLanguage)}&sort=${currentSort}&days=${opt.value}`}
              class:list={[
                'px-3 py-1.5 text-sm transition-all duration-200 whitespace-nowrap',
                currentDays === opt.value
                  ? 'bg-gradient-to-r from-neon-green to-emerald-400 text-white font-semibold'
                  : 'text-neon-text-secondary hover:text-neon-text hover:bg-white/5',
              ]}
            >
              {opt.label}
            </a>
          ))}
        </div>

        <!-- Sort dropdown -->
        <div class="relative">
          <select
            id="sort-select"
            class="appearance-none glass text-neon-text text-sm rounded-xl px-4 py-2 pr-8 cursor-pointer hover:border-neon-accent/30 focus:border-neon-accent/50 focus:outline-none transition-colors"
            onchange={`window.location.href='/?lang=${encodeURIComponent(currentLanguage)}&days=${currentDays}&sort='+this.value`}
          >
            {SORT_OPTIONS.map((opt) => (
              <option value={opt.value} selected={currentSort === opt.value}>
                {opt.label}
              </option>
            ))}
          </select>
          <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-neon-text-secondary">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
