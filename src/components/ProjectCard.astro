---
import type { GitHubRepo } from '../lib/github';
import { formatStars, formatDate, getLanguageColor } from '../lib/github';

interface Props {
  repo: GitHubRepo;
  rank: number;
}

const { repo, rank } = Astro.props;
const languageColor = getLanguageColor(repo.language);

const rankClass = rank === 1 ? 'rank-gold' : rank === 2 ? 'rank-silver' : rank === 3 ? 'rank-bronze' : '';
const rankLabel = rank === 1 ? '🥇' : rank === 2 ? '🥈' : rank === 3 ? '🥉' : rank;
---

<article data-repo-name={repo.full_name} class="card-animate group relative glass rounded-xl p-5 transition-all duration-300 hover:-translate-y-1 hover:shadow-lg" style="border-color: var(--glass-border);" onmouseenter="this.style.borderColor='var(--border-hover)'; this.style.boxShadow='0 0 20px rgba(99,102,241,0.1)'" onmouseleave="this.style.borderColor='var(--glass-border)'; this.style.boxShadow=''">
  <!-- Rank badge -->
  <div class={`absolute -top-2.5 -left-2.5 w-8 h-8 rounded-full flex items-center justify-center text-xs font-bold transition-all duration-300 ${rankClass || ''}`} style={rank > 3 ? 'background: var(--bg-card-solid); border: 1px solid var(--border); color: var(--text-secondary);' : ''}>
    {rank <= 3 ? (
      <span class="text-sm">{rankLabel}</span>
    ) : (
      <span>{rank}</span>
    )}
  </div>

  <!-- Header -->
  <div class="flex items-start gap-3 mb-3">
    <img
      src={repo.owner.avatar_url}
      alt={repo.owner.login}
      class="w-10 h-10 rounded-full"
      style="border: 1px solid var(--border);"
      loading="lazy"
      width="40"
      height="40"
    />
    <div class="flex-1 min-w-0">
      <a
        href={`/repo/${repo.owner.login}/${repo.name}`}
        class="hover:opacity-80 font-semibold text-base leading-tight truncate block transition-colors"
        style="color: var(--accent);"
      >
        {repo.full_name}
      </a>
      <p class="text-sm mt-1 line-clamp-2" style="color: var(--text-secondary);">
        {repo.description || 'No description provided'}
      </p>
    </div>
    <!-- Action buttons -->
    <div class="flex flex-col gap-1 shrink-0">
      <button
        data-fav-btn={repo.full_name}
        class="fav-btn w-8 h-8 flex items-center justify-center rounded-lg hover:opacity-80 transition-colors cursor-pointer"
        style="color: var(--text-secondary);"
        title="Add to favorites"
      >
        <span class="fav-icon text-lg">☆</span>
      </button>
      <button
        class="share-btn w-8 h-8 flex items-center justify-center rounded-lg hover:opacity-80 transition-colors cursor-pointer"
        style="color: var(--text-secondary);"
        data-share-url={repo.html_url}
        title="Copy link"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Stats -->
  <div class="flex items-center gap-4 mt-4 text-sm">
    <span class="flex items-center gap-1" style="color: var(--orange);" title="Total stars">
      ⭐ {formatStars(repo.stargazers_count)}
    </span>
    {repo.language && (
      <span class="flex items-center gap-1.5">
        <span class="w-2.5 h-2.5 rounded-full inline-block" style={`background-color: ${languageColor}`}></span>
        <span style="color: var(--text-secondary);">{repo.language}</span>
      </span>
    )}
    <span class="ml-auto text-xs" style="color: var(--text-secondary);" title="Last updated">
      {formatDate(repo.updated_at)}
    </span>
  </div>

  <!-- Topics -->
  {repo.topics && repo.topics.length > 0 && (
    <div class="flex flex-wrap gap-1.5 mt-3">
      {repo.topics.slice(0, 5).map((topic) => (
        <span class="px-2 py-0.5 text-xs rounded-full" style="background: rgba(99,102,241,0.08); color: var(--accent); border: 1px solid rgba(99,102,241,0.15);">
          {topic}
        </span>
      ))}
      {repo.topics.length > 5 && (
        <span class="px-2 py-0.5 text-xs" style="color: var(--text-secondary);">
          +{repo.topics.length - 5}
        </span>
      )}
    </div>
  )}

  <!-- Actions -->
  <div class="mt-4 pt-3 flex gap-2" style="border-top: 1px solid var(--border);">
    <a
      href={`/repo/${repo.owner.login}/${repo.name}`}
      class="flex-1 flex items-center justify-center gap-2 px-3 py-2 text-sm font-medium glass rounded-lg hover:opacity-80 transition-all duration-200"
      style="color: var(--text-secondary);"
    >
      📋 Details
    </a>
    <button
      class="compare-btn w-9 h-9 flex items-center justify-center text-sm rounded-lg border cursor-pointer transition-all duration-200"
      style="border-color: var(--border); color: var(--text-secondary);"
      data-repo={JSON.stringify({
        full_name: repo.full_name,
        description: repo.description,
        language: repo.language,
        stargazers_count: repo.stargazers_count,
        topics: repo.topics,
        html_url: repo.html_url,
      })}
      title="Compare"
    >
      ⚖️
    </button>
    <button
      class="ai-summary-btn flex-1 flex items-center justify-center gap-2 px-3 py-2 text-sm font-medium rounded-lg cursor-pointer transition-all duration-200"
      style="background: rgba(99,102,241,0.1); border: 1px solid rgba(99,102,241,0.2); color: var(--accent);"
      data-repo={JSON.stringify({
        full_name: repo.full_name,
        description: repo.description,
        language: repo.language,
        stargazers_count: repo.stargazers_count,
        topics: repo.topics,
        html_url: repo.html_url,
      })}
    >
      🧠 AI Insight
    </button>
  </div>
</article>

<script>
  document.querySelectorAll('.ai-summary-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const repo = JSON.parse(btn.getAttribute('data-repo') || '{}');
      if (window.openAiSummary) {
        window.openAiSummary(repo);
      }
    });
  });

  document.querySelectorAll('.compare-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const repo = JSON.parse(btn.getAttribute('data-repo') || '{}');
      const state = window.__getCompareState && window.__getCompareState();
      if (!state) return;

      const idx = state.selected.findIndex(r => r.full_name === repo.full_name);
      if (idx >= 0) {
        state.selected.splice(idx, 1);
        btn.classList.remove('active');
        (btn as HTMLElement).style.borderColor = 'var(--border)';
        (btn as HTMLElement).style.color = 'var(--text-secondary)';
        (btn as HTMLElement).style.background = '';
        return;
      }

      if (state.selected.length >= 2) return;

      state.selected.push(repo);
      btn.classList.add('active');
      (btn as HTMLElement).style.borderColor = 'var(--orange)';
      (btn as HTMLElement).style.color = 'var(--orange)';
      (btn as HTMLElement).style.background = 'rgba(245,158,11,0.1)';

      if (state.selected.length === 2) {
        if (window.openAiCompare) {
          window.openAiCompare(state.selected[0], state.selected[1]);
        }
        setTimeout(() => {
          state.clear();
        }, 500);
      }
    });
  });

  document.querySelectorAll('.fav-btn').forEach(btn => {
    const fullName = btn.getAttribute('data-fav-btn') || '';
    try {
      const favs = JSON.parse(localStorage.getItem('github-trending-favorites') || '[]');
      if (favs.includes(fullName)) {
        btn.querySelector('.fav-icon').textContent = '★';
        (btn as HTMLElement).style.color = 'var(--orange)';
      }
    } catch {}
    btn.addEventListener('click', () => {
      if (window.__toggleFavorite) window.__toggleFavorite(fullName);
    });
  });

  document.querySelectorAll('.share-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const url = btn.getAttribute('data-share-url') || '';
      try {
        await navigator.clipboard.writeText(url);
        const toast = document.createElement('div');
        toast.className = 'fixed bottom-20 left-1/2 -translate-x-1/2 z-50 glass px-4 py-2 rounded-xl text-sm shadow-lg';
        toast.style.color = 'var(--green)';
        toast.style.borderColor = 'rgba(22,163,74,0.2)';
        toast.textContent = '✅ Link copied!';
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 2000);
      } catch {
        const ta = document.createElement('textarea');
        ta.value = url;
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        ta.remove();
      }
    });
  });
</script>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
