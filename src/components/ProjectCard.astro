---
import type { GitHubRepo } from '../lib/github';
import { formatStars, formatDate, getLanguageColor } from '../lib/github';

interface Props {
  repo: GitHubRepo;
  rank: number;
}

const { repo, rank } = Astro.props;
const languageColor = getLanguageColor(repo.language);
---

<article data-repo-name={repo.full_name} class="card-animate group relative bg-github-card border border-github-border rounded-lg p-5 hover:border-github-accent/50 transition-all duration-300 hover:shadow-lg hover:shadow-github-accent/5 hover:-translate-y-1">
  <!-- Rank badge -->
  <div class="absolute -top-2 -left-2 w-7 h-7 bg-github-accent text-github-darker rounded-full flex items-center justify-center text-xs font-bold opacity-90 group-hover:opacity-100 transition-opacity">
    {rank}
  </div>

  <!-- Header -->
  <div class="flex items-start gap-3 mb-3">
    <img
      src={repo.owner.avatar_url}
      alt={repo.owner.login}
      class="w-10 h-10 rounded-full border border-github-border"
      loading="lazy"
      width="40"
      height="40"
    />
    <div class="flex-1 min-w-0">
      <a
        href={`/repo/${repo.owner.login}/${repo.name}`}
        class="text-github-accent hover:underline font-semibold text-lg leading-tight truncate block"
      >
        {repo.full_name}
      </a>
      <p class="text-github-text-secondary text-sm mt-1 line-clamp-2">
        {repo.description || 'No description provided'}
      </p>
    </div>
    <!-- Action buttons -->
    <div class="flex flex-col gap-1 shrink-0">
      <button
        data-fav-btn={repo.full_name}
        class="fav-btn w-8 h-8 flex items-center justify-center rounded-lg hover:bg-github-darker transition-colors cursor-pointer text-github-text-secondary"
        title="Add to favorites"
      >
        <span class="fav-icon text-lg">☆</span>
      </button>
      <button
        class="share-btn w-8 h-8 flex items-center justify-center rounded-lg hover:bg-github-darker transition-colors cursor-pointer text-github-text-secondary"
        data-share-url={repo.html_url}
        title="Copy link"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Stats -->
  <div class="flex items-center gap-4 mt-4 text-sm">
    <span class="flex items-center gap-1 text-github-orange" title="Total stars">
      ⭐ {formatStars(repo.stargazers_count)}
    </span>
    {repo.language && (
      <span class="flex items-center gap-1.5">
        <span class="w-3 h-3 rounded-full inline-block" style={`background-color: ${languageColor}`}></span>
        <span class="text-github-text-secondary">{repo.language}</span>
      </span>
    )}
    <span class="text-github-text-secondary ml-auto" title="Last updated">
      Updated {formatDate(repo.updated_at)}
    </span>
  </div>

  <!-- Topics -->
  {repo.topics && repo.topics.length > 0 && (
    <div class="flex flex-wrap gap-1.5 mt-3">
      {repo.topics.slice(0, 5).map((topic) => (
        <span class="px-2 py-0.5 bg-github-accent/10 text-github-accent text-xs rounded-full border border-github-accent/20">
          {topic}
        </span>
      ))}
      {repo.topics.length > 5 && (
        <span class="px-2 py-0.5 text-github-text-secondary text-xs">
          +{repo.topics.length - 5}
        </span>
      )}
    </div>
  )}
  <!-- AI Summary + Compare + View Details -->
  <div class="mt-3 pt-3 border-t border-github-border flex gap-2">
    <a
      href={`/repo/${repo.owner.login}/${repo.name}`}
      class="flex-1 flex items-center justify-center gap-2 px-3 py-2 text-sm font-medium text-github-text-secondary bg-github-darker border border-github-border rounded-lg hover:text-github-accent hover:border-github-accent/40 transition-all duration-200"
    >
      📋 Details
    </a>
    <button
      class="compare-btn w-9 h-9 flex items-center justify-center text-sm rounded-lg border border-github-border text-github-text-secondary hover:text-github-orange hover:border-github-orange/40 transition-all duration-200 cursor-pointer"
      data-repo={JSON.stringify({
        full_name: repo.full_name,
        description: repo.description,
        language: repo.language,
        stargazers_count: repo.stargazers_count,
        topics: repo.topics,
        html_url: repo.html_url,
      })}
      title="选择对比"
    >
      ⚖️
    </button>
    <button
      class="ai-summary-btn flex-1 flex items-center justify-center gap-2 px-3 py-2 text-sm font-medium text-github-accent bg-github-accent/5 border border-github-accent/20 rounded-lg hover:bg-github-accent/10 hover:border-github-accent/40 transition-all duration-200 cursor-pointer"
      data-repo={JSON.stringify({
        full_name: repo.full_name,
        description: repo.description,
        language: repo.language,
        stargazers_count: repo.stargazers_count,
        topics: repo.topics,
        html_url: repo.html_url,
      })}
    >
      🤖 AI
    </button>
  </div>
</article>

<script>
  document.querySelectorAll('.ai-summary-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const repo = JSON.parse(btn.getAttribute('data-repo') || '{}');
      if (window.openAiSummary) {
        window.openAiSummary(repo);
      }
    });
  });

  // Compare button logic
  document.querySelectorAll('.compare-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const repo = JSON.parse(btn.getAttribute('data-repo') || '{}');
      const state = window.__getCompareState && window.__getCompareState();
      if (!state) return;

      const idx = state.selected.findIndex(r => r.full_name === repo.full_name);
      if (idx >= 0) {
        // Deselect
        state.selected.splice(idx, 1);
        btn.classList.remove('border-github-orange', 'text-github-orange', 'bg-github-orange/10');
        btn.classList.add('border-github-border', 'text-github-text-secondary');
        return;
      }

      if (state.selected.length >= 2) return;

      state.selected.push(repo);
      btn.classList.add('border-github-orange', 'text-github-orange', 'bg-github-orange/10');
      btn.classList.remove('border-github-border', 'text-github-text-secondary');

      if (state.selected.length === 2) {
        // Auto-trigger compare
        if (window.openAiCompare) {
          window.openAiCompare(state.selected[0], state.selected[1]);
        }
        // Reset after a short delay
        setTimeout(() => {
          state.clear();
        }, 500);
      }
    });
  });

  // Favorites
  document.querySelectorAll('.fav-btn').forEach(btn => {
    const fullName = btn.getAttribute('data-fav-btn') || '';
    // Set initial state
    try {
      const favs = JSON.parse(localStorage.getItem('github-trending-favorites') || '[]');
      if (favs.includes(fullName)) {
        btn.querySelector('.fav-icon').textContent = '★';
        btn.classList.add('text-github-orange');
        btn.classList.remove('text-github-text-secondary');
      }
    } catch {}
    btn.addEventListener('click', () => {
      if (window.__toggleFavorite) window.__toggleFavorite(fullName);
    });
  });

  // Share
  document.querySelectorAll('.share-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const url = btn.getAttribute('data-share-url') || '';
      try {
        await navigator.clipboard.writeText(url);
        // Show toast
        const toast = document.createElement('div');
        toast.className = 'fixed bottom-20 left-1/2 -translate-x-1/2 z-50 bg-github-text text-white px-4 py-2 rounded-lg text-sm shadow-lg';
        toast.textContent = '✅ Link copied to clipboard!';
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 2000);
      } catch {
        // Fallback
        const ta = document.createElement('textarea');
        ta.value = url;
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        ta.remove();
      }
    });
  });
</script>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
