---
import type { GitHubRepo } from '../lib/github';
import { formatStars, formatDate, getLanguageColor } from '../lib/github';

interface Props {
  repo: GitHubRepo;
  rank: number;
}

const { repo, rank } = Astro.props;
const languageColor = getLanguageColor(repo.language);
---

<article class="card-animate group relative bg-github-card border border-github-border rounded-lg p-5 hover:border-github-accent/50 transition-all duration-300 hover:shadow-lg hover:shadow-github-accent/5 hover:-translate-y-1">
  <!-- Rank badge -->
  <div class="absolute -top-2 -left-2 w-7 h-7 bg-github-accent text-github-darker rounded-full flex items-center justify-center text-xs font-bold opacity-90 group-hover:opacity-100 transition-opacity">
    {rank}
  </div>

  <!-- Header -->
  <div class="flex items-start gap-3 mb-3">
    <img
      src={repo.owner.avatar_url}
      alt={repo.owner.login}
      class="w-10 h-10 rounded-full border border-github-border"
      loading="lazy"
      width="40"
      height="40"
    />
    <div class="flex-1 min-w-0">
      <a
        href={repo.html_url}
        target="_blank"
        rel="noopener noreferrer"
        class="text-github-accent hover:underline font-semibold text-lg leading-tight truncate block"
      >
        {repo.full_name}
      </a>
      <p class="text-github-text-secondary text-sm mt-1 line-clamp-2">
        {repo.description || 'No description provided'}
      </p>
    </div>
  </div>

  <!-- Stats -->
  <div class="flex items-center gap-4 mt-4 text-sm">
    <span class="flex items-center gap-1 text-github-orange" title="Total stars">
      ⭐ {formatStars(repo.stargazers_count)}
    </span>
    {repo.language && (
      <span class="flex items-center gap-1.5">
        <span class="w-3 h-3 rounded-full inline-block" style={`background-color: ${languageColor}`}></span>
        <span class="text-github-text-secondary">{repo.language}</span>
      </span>
    )}
    <span class="text-github-text-secondary ml-auto" title="Last updated">
      Updated {formatDate(repo.updated_at)}
    </span>
  </div>

  <!-- Topics -->
  {repo.topics && repo.topics.length > 0 && (
    <div class="flex flex-wrap gap-1.5 mt-3">
      {repo.topics.slice(0, 5).map((topic) => (
        <span class="px-2 py-0.5 bg-github-accent/10 text-github-accent text-xs rounded-full border border-github-accent/20">
          {topic}
        </span>
      ))}
      {repo.topics.length > 5 && (
        <span class="px-2 py-0.5 text-github-text-secondary text-xs">
          +{repo.topics.length - 5}
        </span>
      )}
    </div>
  )}
</article>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
